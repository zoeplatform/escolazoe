rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Perfil do usuário
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Progresso das aulas (subcoleção — precisa de regra EXPLÍCITA)
      match /progress/{courseId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Progresso da biblioteca de leitura
      match /libraryProgress/{bookId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
